# Copy this file to .env.local for local development.
# .env.local is gitignored; real secrets never get committed.
# In production, set these in the Vercel dashboard (Settings -> Environment Variables).

# Public site URL used for canonical links, OG tags, sitemap.
# Vercel will override this automatically on deploy.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (add when checkout is wired in — leave blank until then)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
